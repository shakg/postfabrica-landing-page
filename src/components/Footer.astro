---
const cols = [
  {
    title: "Research",
    links: [
      { href: "/", label: "Deep Dives" },
      { href: "/qt-patterns-guide", label: "Qt/QML Guide" },
    ]
  },
  {
    title: "Source",
    links: [
      { href: "https://github.com/shakg/qt-patterns-guide", label: "Qt Patterns Repo" },
      { href: "https://github.com/shakg/postfabrica-landing-page", label: "This Site" },
    ]
  },
  {
    title: "Postfabrica",
    links: [
      { href: "https://github.com/shakg", label: "GitHub" },
      { href: "mailto:1sh4kg0nu1@gmail.com", label: "Contact" },
    ]
  }
];
---

<footer class="bg-bg border-t border-stroke">
  <div class="container-wide py-10">
    <div class="grid md:grid-cols-12 gap-6">
      <div class="md:col-span-5">
        <a href="/" class="font-medium tracking-tight text-text">postfabrica</a>
        <span class="text-text-3 text-xs font-mono ml-1.5">.research</span>
        <p class="mt-3 text-sm text-text-2 leading-relaxed max-w-sm">
          Deep technical analysis. Source code, architecture patterns, and best practices —
          compiled from real production codebases.
        </p>
        <p class="mt-3 text-xs text-text-3 font-mono">© 2026 Postfabrica</p>
      </div>

      <div class="md:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-5">
        {cols.map((c) => (
          <div>
            <p class="label mb-2.5">{c.title}</p>
            <ul class="space-y-1.5 text-sm text-text-2">
              {c.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="hover:text-text transition-colors"
                    target={l.href.startsWith("http") ? "_blank" : undefined}
                    rel={l.href.startsWith("http") ? "noopener" : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</footer>
