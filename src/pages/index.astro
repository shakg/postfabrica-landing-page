---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { deepDives, allTopics, allTags } from "../data/deepdives";

const title = "Postfabrica — Deep technical research & analysis";
const description = "A research hub for deep technical analysis. Source code, architecture patterns, and best practices — compiled from real production codebases.";

// Sort: featured first, then by date desc
const sortedDives = [...deepDives].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});
---

<Layout {title} {description}>
  <main id="main" class="min-h-screen">
    <!-- ─── Filter bar ─── -->
    <div class="sticky top-0 z-40 backdrop-blur-md bg-dark-bg/80 border-b border-dark-stroke">
      <div class="container-wide py-4 space-y-3">
        <div id="topic-filters" class="flex flex-wrap gap-2 items-center">
          <span class="label mr-1">Topics</span>
          <button data-topic="all" class="filter-btn active">All</button>
          {allTopics.map((t) => (
            <button data-topic={t} class="filter-btn">{t}</button>
          ))}
        </div>
        <div id="tag-filters" class="flex flex-wrap gap-2 items-center">
          <span class="label mr-1">Tags</span>
          {allTags.map((t) => (
            <button data-tag={t} class="filter-tag">{t}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── Deep dive list ─── -->
    <div class="container-wide py-8">
      <div id="dive-grid" class="flex flex-col">
        {sortedDives.map((dive) => (
          <article
            class="dive-card group border-b border-dark-stroke last:border-b-0 transition-colors hover:bg-dark-bg-hover"
            data-topics={dive.topics.join(",")}
            data-tags={dive.tags.join(",")}
            data-slug={dive.slug}
          >
            <a
              href={dive.externalUrl || `/${dive.slug}`}
              class="block py-8 md:py-12"
              target={dive.externalUrl ? "_blank" : undefined}
              rel={dive.externalUrl ? "noopener" : undefined}
            >
              <div class="grid md:grid-cols-12 gap-4 md:gap-8 items-start">
                <!-- Left: meta -->
                <div class="md:col-span-3 flex flex-col gap-2">
                  <div class="flex flex-wrap gap-1.5">
                    {dive.topics.map((t) => (
                      <span class="text-[10px] font-mono uppercase tracking-wider text-dark-text-tertiary border border-dark-stroke px-2 py-0.5">
                        {t}
                      </span>
                    ))}
                  </div>
                  <div class="flex items-center gap-2 text-xs text-dark-text-tertiary font-mono">
                    <span>{dive.date}</span>
                    <span>·</span>
                    <span>{dive.readTime}</span>
                  </div>
                </div>

                <!-- Middle: title + excerpt -->
                <div class="md:col-span-7">
                  <h2 class="display text-xl md:text-2xl font-medium leading-tight text-dark-text group-hover:text-accent transition-colors mb-3">
                    {dive.title}
                  </h2>
                  <p class="text-sm text-dark-text-secondary leading-relaxed max-w-2xl">
                    {dive.excerpt}
                  </p>
                  {dive.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-4">
                      {dive.tags.map((t) => (
                        <span class="text-[10px] font-mono text-dark-text-tertiary">
                          #{t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>

                <!-- Right: arrow -->
                <div class="md:col-span-2 flex md:justify-end">
                  <span class="text-dark-text-tertiary group-hover:text-accent group-hover:translate-x-1 transition-all text-lg" aria-hidden="true">
                    →
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-20">
        <p class="text-dark-text-secondary text-sm">No deep dives match your filters.</p>
        <button id="reset-filters" class="btn-ghost mt-4 text-sm">Reset filters</button>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  /* Filter buttons — sharp rectangles */
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-dark-stroke);
    background: transparent;
    color: var(--color-dark-text-tertiary);
    cursor: pointer;
    transition: all 0.15s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .filter-btn:hover {
    border-color: var(--color-dark-text);
    color: var(--color-dark-text);
  }
  .filter-btn.active {
    background: var(--color-dark-text);
    color: var(--color-dark-bg);
    border-color: var(--color-dark-text);
  }

  .filter-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-dark-stroke);
    background: transparent;
    color: var(--color-dark-text-tertiary);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-dark-text);
  }
  .filter-tag.active {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Code blocks — dark, no rounded corners */
  pre {
    scrollbar-width: thin;
    scrollbar-color: var(--color-dark-stroke) transparent;
  }
  pre::-webkit-scrollbar {
    height: 4px;
  }
  pre::-webkit-scrollbar-thumb {
    background: var(--color-dark-stroke);
  }
</style>

<script>
  // ─── Client-side filtering ───
  const topicButtons = document.querySelectorAll<HTMLButtonElement>("[data-topic]");
  const tagButtons = document.querySelectorAll<HTMLButtonElement>("[data-tag]");
  const cards = document.querySelectorAll<HTMLElement>(".dive-card");
  const emptyState = document.getElementById("empty-state");

  let activeTopic = "all";
  let activeTags = new Set<string>();

  function update() {
    let visible = 0;

    cards.forEach((card) => {
      const cardTopics = (card.dataset.topics || "").split(",");
      const cardTags = (card.dataset.tags || "").split(",");

      const topicMatch = activeTopic === "all" || cardTopics.includes(activeTopic);
      const tagMatch = activeTags.size === 0 || [...activeTags].some((t) => cardTags.includes(t));

      if (topicMatch && tagMatch) {
        card.classList.remove("hidden");
        visible++;
      } else {
        card.classList.add("hidden");
      }
    });

    if (emptyState) {
      emptyState.classList.toggle("hidden", visible > 0);
    }
  }

  topicButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      topicButtons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeTopic = btn.dataset.topic || "all";
      update();
    });
  });

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag || "";
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove("active");
      } else {
        activeTags.add(tag);
        btn.classList.add("active");
      }
      update();
    });
  });

  document.getElementById("reset-filters")?.addEventListener("click", () => {
    activeTopic = "all";
    activeTags.clear();
    topicButtons.forEach((b) => b.classList.toggle("active", b.dataset.topic === "all"));
    tagButtons.forEach((b) => b.classList.remove("active"));
    update();
  });
</script>
