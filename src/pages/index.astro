---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { deepDives, allTopics, allTags } from "../data/deepdives";

const title = "Postfabrica — Deep technical research & analysis";
const description = "A research hub for deep technical analysis. Source code, architecture patterns, and best practices — compiled from real production codebases.";

const sortedDives = [...deepDives].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});
---

<Layout {title} {description}>
  <main id="main" class="min-h-screen">
    <!-- ─── Filter bar ─── -->
    <div class="sticky top-0 z-40 backdrop-blur-md bg-bg/90 border-b border-stroke">
      <div class="container-wide py-3.5 space-y-2.5">
        <div id="topic-filters" class="flex flex-wrap gap-1.5 items-center">
          <span class="label mr-1.5">Topics</span>
          <button data-topic="all" class="filter-btn active">All</button>
          {allTopics.map((t) => (
            <button data-topic={t} class="filter-btn">{t}</button>
          ))}
        </div>
        <div id="tag-filters" class="flex flex-wrap gap-1.5 items-center">
          <span class="label mr-1.5">Tags</span>
          {allTags.map((t) => (
            <button data-tag={t} class="filter-tag">{t}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- ─── Deep dive list ─── -->
    <div class="container-wide py-6">
      <div id="dive-grid" class="flex flex-col">
        {sortedDives.map((dive) => (
          <article
            class="dive-card group border-b border-stroke last:border-b-0 transition-colors hover:bg-bg-hover"
            data-topics={dive.topics.join(",")}
            data-tags={dive.tags.join(",")}
            data-slug={dive.slug}
          >
            <a
              href={dive.externalUrl || `/${dive.slug}`}
              class="block py-7 md:py-9"
              target={dive.externalUrl ? "_blank" : undefined}
              rel={dive.externalUrl ? "noopener" : undefined}
            >
              <div class="grid md:grid-cols-12 gap-3 md:gap-6 items-start">
                <!-- Left: meta -->
                <div class="md:col-span-3 flex flex-col gap-2">
                  <div class="flex flex-wrap gap-1">
                    {dive.topics.map((t) => (
                      <span class="text-[10px] font-mono uppercase tracking-wider text-text-3 border border-stroke px-1.5 py-0.5">
                        {t}
                      </span>
                    ))}
                  </div>
                  <div class="flex items-center gap-2 text-xs text-text-3 font-mono">
                    <span>{dive.date}</span>
                    <span>·</span>
                    <span>{dive.readTime}</span>
                  </div>
                </div>

                <!-- Middle: title + excerpt -->
                <div class="md:col-span-7">
                  <h2 class="display text-xl md:text-2xl font-medium leading-tight text-text group-hover:text-accent transition-colors mb-2.5">
                    {dive.title}
                  </h2>
                  <p class="text-sm text-text-2 leading-relaxed max-w-2xl">
                    {dive.excerpt}
                  </p>
                  {dive.tags.length > 0 && (
                    <div class="flex flex-wrap gap-x-3 gap-y-1 mt-3">
                      {dive.tags.map((t) => (
                        <span class="text-[10px] font-mono text-text-3">#{t}</span>
                      ))}
                    </div>
                  )}
                </div>

                <!-- Right: arrow -->
                <div class="md:col-span-2 flex md:justify-end">
                  <span class="text-text-3 group-hover:text-accent group-hover:translate-x-1 transition-all text-lg" aria-hidden="true">
                    →
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-20">
        <p class="text-text-2 text-sm">No deep dives match your filters.</p>
        <button id="reset-filters" class="btn-ghost mt-4">Reset filters</button>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-stroke);
    background: transparent;
    color: var(--color-text-3);
    cursor: pointer;
    transition: all 0.15s ease;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .filter-btn:hover {
    border-color: var(--color-text-2);
    color: var(--color-text-2);
  }
  .filter-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .filter-tag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--color-stroke);
    background: transparent;
    color: var(--color-text-3);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-text-2);
  }
  .filter-tag.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<script>
  const topicButtons = document.querySelectorAll("[data-topic]");
  const tagButtons = document.querySelectorAll("[data-tag]");
  const cards = document.querySelectorAll(".dive-card");
  const emptyState = document.getElementById("empty-state");

  let activeTopic = "all";
  let activeTags = new Set();

  function update() {
    let visible = 0;
    cards.forEach((card) => {
      const ct = (card.dataset.topics || "").split(",");
      const cg = (card.dataset.tags || "").split(",");
      const tm = activeTopic === "all" || ct.includes(activeTopic);
      const gm = activeTags.size === 0 || [...activeTags].some((t) => cg.includes(t));
      if (tm && gm) { card.classList.remove("hidden"); visible++; }
      else { card.classList.add("hidden"); }
    });
    if (emptyState) emptyState.classList.toggle("hidden", visible > 0);
  }

  topicButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      topicButtons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeTopic = btn.dataset.topic || "all";
      update();
    });
  });

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag || "";
      if (activeTags.has(tag)) { activeTags.delete(tag); btn.classList.remove("active"); }
      else { activeTags.add(tag); btn.classList.add("active"); }
      update();
    });
  });

  document.getElementById("reset-filters")?.addEventListener("click", () => {
    activeTopic = "all";
    activeTags.clear();
    topicButtons.forEach((b) => b.classList.toggle("active", b.dataset.topic === "all"));
    tagButtons.forEach((b) => b.classList.remove("active"));
    update();
  });
</script>
