---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const principles = [
  { n: "01", text: "Sahaya bakmadan teklif verilmez. İşin nerede aktığını görmeden çözüm satılmaz." },
  { n: "02", text: "Önce en düşük maliyetli katman denenir. Basit çözüm yetiyorsa pahalı çözüm önerilmez." },
  { n: "03", text: "Müşteriyi araca bağımlı bırakmak tasarım hatasıdır. Kod, akış ve doküman müşteriye ait olur." },
  { n: "04", text: "Ekip neredeyse sistem orada çalışır. Çoğu KOBİ için ilk doğru ekran Telegram’dır." },
  { n: "05", text: "Özel kod son çaredir. Önce hazır, sürdürülebilir ve açık kaynak çözümler değerlendirilir." },
  { n: "06", text: "Kara kutu teslim edilmez. Müşteri neyin neden çalıştığını anlayacak kadar sistemi sahiplenir." },
  { n: "07", text: "Rapor değil, çalışan akış teslim edilir. Sunum ancak çalışan şeyin yanında anlamlıdır." },
  { n: "08", text: "Uymayan işe “uymaz” denir. Kısa vadeli satış, uzun vadeli güvenin önüne geçmez." },
  { n: "09", text: "Müşteri verisi müşteride kalır. Gereksiz veri dışarı çıkmaz, kritik karar insanda kalır." },
  { n: "10", text: "Az ama doğru müşteriyle derin çalışılır. İyi otomasyon, işi ve insanı tanımadan kurulmaz." }
];
---

<Layout
  title="Manifesto — Postfabrica"
  description="Postfabrica’nın 10 temel ilkesi. Sahaya bakmadan teklif verme, sade çözüm kur, müşteriyi araca bağımlı bırakma, veriyi müşteride tut."
>
  <Nav />
  <main id="main" class="container-wide py-20 md:py-28">
    <div class="max-w-3xl mb-16">
      <p class="label mb-4">Manifesto</p>
      <h1 class="display text-5xl md:text-7xl font-medium tracking-tight mb-6">
        Sistemi kurarız. Sahibinin siz olmasını isteriz.
      </h1>
      <p class="text-lg text-ink/70 leading-relaxed">
        Postfabrica’nın iş yapma biçimi bu 10 ilkeye dayanır. Sözümüz sade: sahayı görür, gereksiz karmaşayı azaltır, çalışan akışı teslim ederiz.
      </p>
    </div>

    <ol class="space-y-3 max-w-3xl">
      {principles.map((p) => (
        <li class="flex gap-5 p-5 md:p-6 rounded-xl bg-paper border border-line">
          <span class="font-mono text-xs text-muted shrink-0 pt-1">{p.n}</span>
          <p class="text-ink/85 leading-relaxed text-lg">{p.text}</p>
        </li>
      ))}
    </ol>

    <div class="mt-16 max-w-3xl border-l-2 border-accent pl-6 py-2">
      <p class="text-ink/80 leading-relaxed">
        Bu ilkeler kendimizi bağlamak için yazıldı. Daha iyi bir yol gördüğümüzde savunmaya değil, düzeltmeye bakarız.
      </p>
    </div>

    <div class="mt-16">
      <a href="/" class="btn-ghost">← Ana sayfaya dön</a>
    </div>
  </main>
  <Footer />
</Layout>
