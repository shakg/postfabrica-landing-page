---
const sectors = [
  {
    code: "A",
    name: "Toptan / e-ticaret dağıtım",
    bullets: [
      "Sipariş kanalları çoğaldı; kayıt tek yerde değil",
      "Stok, fatura ve kargo bilgisi elle taşınıyor",
      "WhatsApp / Instagram DM satış akışının merkezi"
    ]
  },
  {
    code: "B",
    name: "Küçük üretim / atölye",
    bullets: [
      "Hammadde, stok ve üretim takibi ayrı yerlerde",
      "Usta, ofis ve sevkiyat aynı bilgiye aynı anda bakamıyor",
      "Teslim tarihi hâlâ telefonda soruluyor"
    ]
  },
  {
    code: "C",
    name: "Ajans / kreatif stüdyo (5-15 kişi)",
    bullets: [
      "Brief, dosya, onay ve fatura farklı yerlerde",
      "Müşteri istekleri kanallar arasında kayboluyor",
      "Tekliften tahsilata takip kişilere bağlı"
    ]
  },
  {
    code: "D",
    name: "Muhasebe / danışmanlık bürosu",
    bullets: [
      "Müşteri evrakı, hatırlatma ve son tarih takibi manuel",
      "Beyan döneminde tekrar eden mesaj ve kontrol yükü artıyor",
      "WhatsApp konuşmaları dosya düzeninin yerini alıyor"
    ]
  },
  {
    code: "E",
    name: "Lojistik / nakliye KOBİ",
    bullets: [
      "Teklif WhatsApp’ta, plaka ve rota ayrı yerde",
      "Şoför, saha ve ofis arasında bilgi geç kalıyor",
      "Sevkiyat onayı telefonda kalıyor"
    ]
  }
];

const anti = [
  "250+ çalışanlı kurumsal yapılar",
  "Sadece web sitesi veya tekil uygulama isteyenler",
  "Süreç göstermeden “AI kuralım” diyenler",
  "Verisini ve işleyişini paylaşmak istemeyenler",
  "Uzun ihale / satın alma süreci gerektiren kamu işleri"
];
---

<section id="kimin-icin" class="py-20 md:py-28">
  <div class="container-wide">
    <div class="max-w-2xl mb-14">
      <p class="label mb-4">Hedef Müşteri</p>
      <h2 class="display text-4xl md:text-5xl font-medium tracking-tight">
        Ekibi büyürken işi dağılan KOBİ’ler için.
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        sectors.map((s) => (
          <article class="card">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-xs px-2 py-1 rounded-full bg-cream border border-line">
                {s.code}
              </span>
              <h3 class="text-lg font-medium tracking-tight">{s.name}</h3>
            </div>
            <ul class="space-y-2 text-sm text-ink/70">
              {s.bullets.map((b) => (
                <li class="flex gap-2">
                  <span class="text-accent shrink-0">·</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }

      <article class="card bg-ink text-paper border-ink">
        <p class="label text-paper/50 mb-4">Hariç tutulanlar</p>
        <h3 class="text-lg font-medium tracking-tight mb-4">
          Bu durumda iyi eşleşmeyiz.
        </h3>
        <ul class="space-y-2 text-sm text-paper/80">
          {
            anti.map((a) => (
              <li class="flex gap-2">
                <span class="text-accent shrink-0">✕</span>
                <span>{a}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>

    <div class="mt-14 max-w-3xl border-l-2 border-accent pl-6 py-2">
      <p class="text-ink/80 leading-relaxed">
        <strong class="text-ink">Karar verici</strong> genelde işletme sahibi veya ortağıdır. Excel’i iyi bilir, birkaç SaaS kullanır; ama hangi işin kime, hangi verinin hangi araca bağlı olduğunu artık net görmek ister.
      </p>
    </div>
  </div>
</section>
