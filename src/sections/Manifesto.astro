---
const principles = [
  {
    n: "01",
    text: "Sahaya bakmadan teklif verilmez."
  },
  {
    n: "02",
    text: "Önce en düşük maliyetli katman denenir."
  },
  {
    n: "03",
    text: "Müşteriyi araca bağımlı bırakmak tasarım hatasıdır."
  },
  {
    n: "04",
    text: "Ekip neredeyse sistem orada çalışır; çoğu zaman Telegram yeterlidir."
  },
  {
    n: "05",
    text: "Özel kod son çaredir; önce hazır ve açık kaynak çözümler değerlendirilir."
  },
  {
    n: "06",
    text: "Kara kutu teslim edilmez; müşteri sistemi sahiplenir."
  },
  {
    n: "07",
    text: "Rapor değil, çalışan akış teslim edilir."
  },
  {
    n: "08",
    text: "Uymayan işe “uymaz” denir."
  },
  {
    n: "09",
    text: "Müşteri verisi müşteride kalır; gereksiz veri dışarı çıkmaz."
  },
  {
    n: "10",
    text: "Az ama doğru müşteriyle derin çalışılır."
  }
];

const faqs = [
  {
    q: "Kurulum nerede çalışacak?",
    a: "Sizin hesabınızda, kendi sunucunuzda veya seçtiğiniz bulut altyapısında çalışabilir. Kurulumu biz yaparız; bakımını ister ekibinize devreder, ister aylık destekle biz üstleniriz."
  },
  {
    q: "Verilerimiz dışarı çıkar mı?",
    a: "Varsayılan yaklaşımımız veriyi mümkün olduğunca sizde tutmaktır. OpenAI / Claude gibi harici API’ler sadece açık onayınızla ve gerekli minimum veriyle kullanılır. İhtiyaç varsa dış API bağımlılığı olmadan da mimari kurabiliriz."
  },
  {
    q: "AI yanlış cevap verirse ne olur?",
    a: "Kritik işlemlerde son karar insanda kalır. Bot size “yapayım mı?” diye sorar; siz onaylamadan ERP’ye yazmaz, müşteriye mesaj atmaz, ödeme veya sevkiyat başlatmaz."
  },
  {
    q: "Mevcut ERP’mize (Logo, Mikro, SAP) bağlanabilir misiniz?",
    a: "Evet. P2 ve P3 kapsamında ERP köprüleri kuruyoruz. P1’de böyle bir ihtiyaç çıkarsa önce teknik uygunluğu ve maliyeti netleştiririz."
  },
  {
    q: "Ekibimiz yeni bir uygulama mı öğrenecek?",
    a: "Çoğu durumda hayır. Onay, uyarı ve raporları Telegram’a taşırız. Yeni panel veya ekran gerekiyorsa da sadece gerçekten değer kattığı yerde kurarız."
  },
  {
    q: "Ürettiğiniz akışlar bize mi ait?",
    a: "Evet. Ödeme tamamlandığında otomasyon dosyaları, kodlar ve dokümanlar size aittir. İsterseniz kendi ekibiniz veya başka bir ekip sistemi geliştirmeye devam edebilir."
  },
  {
    q: "Bize ne kadar zaman ayırmanız gerekir?",
    a: "Başlangıçta 15 dakikalık ön görüşme ve 1 saatlik denetim yeterlidir. Uygulama aşamasında haftalık kısa kontrol görüşmeleriyle ilerleriz; ekibinizi uzun toplantılara boğmayız."
  }
];
---

<section class="py-20 md:py-28 bg-cream/40">
  <div class="container-wide">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <p class="label mb-4">Manifesto</p>
        <h2 class="display text-4xl md:text-5xl font-medium tracking-tight">
          Güven sözle değil, çalışma biçimiyle kurulur.
        </h2>
        <p class="mt-6 text-ink/70 leading-relaxed max-w-md">
          Postfabrica’nın sözleşmeden önce de sonra da değişmeyen çizgisi: sahayı gör, sade kur, sahibini müşteri yap.
        </p>
      </div>

      <ol class="lg:col-span-7 space-y-3">
        {
          principles.map((p) => (
            <li class="flex gap-5 p-4 rounded-xl bg-paper border border-line">
              <span class="font-mono text-xs text-muted shrink-0 pt-1">{p.n}</span>
              <p class="text-ink/85 leading-relaxed">{p.text}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<section id="sss" class="py-20 md:py-28">
  <div class="container-wide max-w-4xl">
    <p class="label mb-4">Sıkça Sorulanlar</p>
    <h2 class="display text-4xl md:text-5xl font-medium tracking-tight mb-12">
      Başvurmadan önce bilmek isteyecekleriniz.
    </h2>

    <div class="space-y-px bg-line border border-line rounded-2xl overflow-hidden">
      {
        faqs.map((f) => (
          <details class="group bg-paper">
            <summary class="cursor-pointer list-none p-5 md:p-6 flex items-center justify-between gap-6 hover:bg-cream/40 transition-colors">
              <span class="font-medium tracking-tight text-ink">{f.q}</span>
              <span
                aria-hidden="true"
                class="text-muted text-xl transition-transform group-open:rotate-45 shrink-0"
              >
                +
              </span>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 -mt-2 text-ink/75 leading-relaxed">
              {f.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
