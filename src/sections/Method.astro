---
const steps = [
  {
    n: "01",
    title: "Darboğazı yerinde buluruz",
    duration: "1 saat",
    body: "İşletmenize geliriz ya da video ile ekranınızı izleriz. Kim neyi, nereden alıp nereye yazıyor netleştiririz.",
    output: "1 sayfalık akış haritası + 3 öncelikli fırsat"
  },
  {
    n: "02",
    title: "En küçük çalışan çözümü kurarız",
    duration: "2-10 hafta",
    body: "Büyük dönüşüm vaadiyle başlamayız. Önce en görünür zaman kaybını alır, çalışır hale getiririz.",
    output: "Otomasyon akışları + kurulum + botlar"
  },
  {
    n: "03",
    title: "Ekibi yeni ekrana zorlamayız",
    duration: "1. günden itibaren",
    body: "Onay, uyarı ve raporları ekibin zaten kullandığı Telegram’a taşırız. Yeni panel ancak gerçekten gerekiyorsa açılır.",
    output: "Sipariş, stok, onay ve rapor botları"
  },
  {
    n: "04",
    title: "Teslim edip kaybolmayız",
    duration: "aylık destek",
    body: "İş değişir, ekip değişir, ihtiyaç büyür. Akışları izler, düzeltir ve yeni fırsatları birlikte seçeriz.",
    output: "Aylık bakım + saatlik destek"
  }
];

const layers = [
  {
    code: "L0",
    name: "Var olan araçları konuştur",
    when: "Aynı veri elle taşınıyor",
    tools: "n8n · Make · Zapier"
  },
  {
    code: "L1",
    name: "Kendi sunucunuzda açık kaynak",
    when: "Abonelik pahalı; veri sizde kalsın",
    tools: "n8n · Twenty CRM · Dolibarr · Nextcloud"
  },
  {
    code: "L2",
    name: "AI destekli otomasyon",
    when: "Okuma, özetleme, sınıflandırma, teklif taslağı",
    tools: "n8n + Ollama/OpenAI · vektör arama"
  },
  {
    code: "L3",
    name: "Özel yazılım ve köprüler",
    when: "Standart araç yetmiyor; ERP bağlantısı şart",
    tools: "Python · FastAPI · özel panel · bot"
  }
];
---

<section id="yontem" class="py-20 md:py-28">
  <div class="container-wide">
    <div class="max-w-2xl mb-14">
      <p class="label mb-4">Yöntem</p>
      <h2 class="display text-4xl md:text-5xl font-medium tracking-tight">
        Önce görürüz. Sonra en küçük çalışan sistemi kurarız.
      </h2>
      <p class="mt-6 text-ink/70 leading-relaxed">
        PowerPoint teslim edip gitmeyiz. 1 saatte başlar, çalışan akış teslim eder, çalıştığı sürece yanında dururuz.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-line border border-line rounded-2xl overflow-hidden">
      {
        steps.map((s) => (
          <article class="bg-paper p-6 md:p-7 h-full flex flex-col">
            <div class="flex items-baseline justify-between mb-4">
              <span class="label text-ink">{s.n}</span>
              <span class="text-[11px] font-mono text-muted">{s.duration}</span>
            </div>
            <h3 class="text-lg font-medium tracking-tight mb-2">{s.title}</h3>
            <p class="text-sm text-ink/70 leading-relaxed flex-1">{s.body}</p>
            <p class="mt-4 pt-3 border-t hairline text-xs text-muted">
              <span class="text-ink font-medium">Çıktı:</span> {s.output}
            </p>
          </article>
        ))
      }
    </div>

    <div class="mt-20">
      <div class="flex items-baseline justify-between mb-8">
        <h3 class="text-2xl md:text-3xl font-medium tracking-tight">
          Önce basit çözüm. Yetmezse bir katman yukarı.
        </h3>
        <span class="hidden md:inline text-xs font-mono text-muted">
          alt ↑ hızlı &amp; düşük maliyet · üst ↓ kapsamlı &amp; nadir
        </span>
      </div>

      <div class="space-y-px bg-line border border-line rounded-2xl overflow-hidden">
        {
          layers.map((l, i) => (
            <div class="grid grid-cols-12 gap-4 items-center bg-paper p-5 md:p-6">
              <div class="col-span-2 md:col-span-1">
                <span class="font-mono text-2xl font-medium text-ink/90">{l.code}</span>
              </div>
              <div class="col-span-10 md:col-span-3">
                <p class="font-medium">{l.name}</p>
              </div>
              <div class="col-span-12 md:col-span-4 text-sm text-ink/70">
                <span class="md:hidden label">Ne zaman: </span>
                {l.when}
              </div>
              <div class="col-span-12 md:col-span-4 font-mono text-xs text-muted">
                {l.tools}
              </div>
            </div>
          ))
        }
      </div>

      <p class="mt-6 text-sm text-ink/70 max-w-3xl">
        <strong class="text-ink">Altın kural:</strong> ihtiyaç çözülüyorsa daha pahalı katmana çıkmayız. Bu yaklaşım bütçeyi korur, sistemi sade tutar ve sizi tek bir tedarikçiye bağımlı hale getirmez.
      </p>
    </div>
  </div>
</section>
