---
const pains = [
  {
    n: "01",
    title: "Her şey birinin hafızasında",
    body: "Sipariş WhatsApp’ta, stok Excel’de, fatura ERP’de, notlar defterde. Bir kişi izin alınca işin nerede kaldığını kimse göremiyor."
  },
  {
    n: "02",
    title: "Araç çok, sistem yok",
    body: "Her ay abonelik ödüyorsunuz; ama araçlar birbirini duymuyor. Aynı veri üç yere yazılıyor, hata da tam orada başlıyor."
  },
  {
    n: "03",
    title: "AI denendi, operasyon değişmedi",
    body: "ChatGPT’ye birkaç prompt yazmak işi otomatikleştirmez. AI, sipariş, stok, teklif ve onay akışına girdiğinde para kazandırır."
  },
  {
    n: "04",
    title: "Rapor değil, çalışan iş gerekir",
    body: "Saha görmeden hazırlanan sunumlar klasörde kalır. İşletme sahibinin ihtiyacı yeni jargon değil; yarın sabah çalışan bir akıştır."
  }
];
---

<section class="py-20 md:py-28 bg-cream/40">
  <div class="container-wide">
    <div class="max-w-2xl mb-14">
      <p class="label mb-4">Problem</p>
      <h2 class="display text-4xl md:text-5xl font-medium tracking-tight">
        Sorun teknoloji eksikliği değil.
        <span class="text-muted italic">İşin nasıl aktığının görünmemesi.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-line border border-line rounded-2xl overflow-hidden">
      {
        pains.map((pain) => (
          <article class="bg-paper p-8 md:p-10">
            <p class="label mb-4 text-accent">{pain.n}</p>
            <h3 class="text-xl md:text-2xl font-medium tracking-tight mb-3">
              {pain.title}
            </h3>
            <p class="text-ink/70 leading-relaxed">{pain.body}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-10 max-w-3xl">
      <p class="text-ink/80 leading-relaxed">
        <strong class="text-ink">Gerçek darboğaz</strong> çoğu zaman yeni yazılım ihtiyacı değil, iki araç arasında elle taşınan iştir. Önce onu buluyoruz. Sonra en küçük çalışan otomasyonu kuruyoruz.
      </p>
    </div>
  </div>
</section>
